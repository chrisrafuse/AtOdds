# AtOdds API Environment Configuration
# Copy this file to .env and customize for your environment

# API Server Configuration
CR_api_host=0.0.0.0
CR_api_port=8000
CR_api_workers=4

# CORS Configuration (comma-separated list)
CR_cors_origins=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# Rate Limiting
CR_rate_limit_default=100/minute
CR_rate_limit_analyze=10/minute
CR_rate_limit_upload=5/minute

# File Upload Limits
CR_max_upload_size_mb=10

# Session Configuration
CR_session_timeout_hours=1
CR_session_cleanup_interval_minutes=15

# Logging
CR_log_level=INFO

# Development Settings
CR_debug_mode=false
CR_reload_on_change=false
