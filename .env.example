# AtOdds Environment Configuration
# Copy this file to .env and fill in your values
# .env is gitignored — never commit API keys

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Select provider: openai | anthropic | gemini | mock
# "mock" requires no API key and uses the deterministic fallback
LLM_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Google Gemini
GEMINI_API_KEY=AI...
GEMINI_MODEL=gemini-1.5-flash

# ── Server ────────────────────────────────────────────────────────────────────
# PORT is set automatically by Railway/Fly.io — only override for local dev
# PORT=8000
# HOST=0.0.0.0
ENVIRONMENT=development

# ── CORS (comma-separated origins for production deployment) ──────────────────
# CORS_ORIGINS=https://your-app.railway.app,https://your-domain.com
